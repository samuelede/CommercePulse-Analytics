# --- Source PostgreSQL (Mandera staging) ---
# These values are for running the pipeline from your HOST (venv, tests, CLI).
# 5434 is the port docker-compose publishes for the data-db service.
#
# When the pipeline runs INSIDE Airflow, docker-compose overrides these with
# the internal service address (data-db:5432). You do not need to set that here.
PG_HOST=127.0.0.1
PG_PORT=5434
PG_DB=mandera
PG_USER=postgres
PG_PASSWORD=postgres
PG_STAGING_SCHEMA=staging
PG_ANALYTICS_SCHEMA=analytics

# --- Holiday API ---
# Calendarific free tier: https://calendarific.com
# Leave the key blank to use the keyless Nager.Date fallback.
HOLIDAY_API_KEY=
HOLIDAY_API_BASE=https://calendarific.com/api/v2
HOLIDAY_COUNTRY=GB
HOLIDAY_YEAR=2026

# Minimum days before a holiday for it to be worth planning a campaign around.
# A holiday two days out is accurate but unusable: no time to brief, build, and
# ship. Set to 0 to select the nearest upcoming holiday regardless.
HOLIDAY_MIN_LEAD_DAYS=14

# Exclude subdivision-specific holidays (e.g. Battle of the Boyne is Northern
# Ireland only, St Andrew's Day is Scotland only). Set false to include them.
HOLIDAY_NATIONWIDE_ONLY=true

# --- Monday CRM ---
# Token: monday.com avatar (bottom-left) > Administration > Developers >
#        My Access Tokens > Show
# Board ID: the number in the board URL, /boards/1234567890
MONDAY_API_TOKEN=
MONDAY_API_URL=https://api.monday.com/v2
MONDAY_BOARD_ID=

# --- Segmentation thresholds ---
VIP_SPEND_THRESHOLD=5000
VIP_ORDER_THRESHOLD=10
RETURNING_ORDER_THRESHOLD=2
CHURN_DAYS_THRESHOLD=90

# --- Airflow ---
# Host port for the Airflow UI. 8080 is heavily contested; change this if
# another container or service already holds it.
AIRFLOW_PORT=8080
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
